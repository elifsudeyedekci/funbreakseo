# =============================================
# FunBreak SEO — Environment Variables
# =============================================

# General
NODE_ENV=production
APP_URL=https://funbreakseo.com
ADMIN_URL=https://admin.funbreakseo.com
API_URL=https://api.funbreakseo.com
PORT=4000

# Database
DATABASE_URL=postgresql://funbreak:STRONG_PASS@localhost:5432/funbreakseo

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Auth
# IMPORTANT: Code uses JWT_SECRET and JWT_REFRESH_SECRET (not JWT_ACCESS_SECRET)
JWT_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_DAYS=30
BCRYPT_ROUNDS=12

# DataForSEO
DATAFORSEO_LOGIN=your-login@example.com
DATAFORSEO_PASSWORD=your-dataforseo-password
DATAFORSEO_BASE_URL=https://api.dataforseo.com
DATAFORSEO_USE_SANDBOX=false

# LLM
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEFAULT_CONTENT_MODEL=claude-sonnet-4-6

# Google OAuth (GSC)
# IMPORTANT: Code uses GOOGLE_CLIENT_ID (not GOOGLE_OAUTH_CLIENT_ID)
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
GSC_REDIRECT_URI=https://api.funbreakseo.com/integrations/gsc/callback

# VakıfBank Sanal POS
# IMPORTANT: Field names must match exactly what the code expects
VAKIFBANK_MERCHANT_ID=
VAKIFBANK_TERMINAL_ID=
VAKIFBANK_POSNET_ID=
VAKIFBANK_PASSWORD=
VAKIFBANK_ENC_KEY=
VAKIFBANK_BASE_URL=https://onlineodeme.vakifbank.com.tr
VAKIFBANK_TEST_BASE_URL=https://onlineodemetest.vakifbank.com.tr

# Stripe (international - initially passive)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_ENABLED=false

# Paraşüt (e-invoice)
PARASUT_CLIENT_ID=
PARASUT_CLIENT_SECRET=
PARASUT_USERNAME=
PARASUT_PASSWORD=
PARASUT_COMPANY_ID=
PARASUT_REDIRECT_URI=https://api.funbreakseo.com/integrations/parasut/callback
PARASUT_BASE_URL=https://api.parasut.com/v4

# Mail (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@funbreakseo.com
SMTP_PASS=your-smtp-password
SMTP_SECURE=false
SMTP_FROM="FunBreak SEO <no-reply@funbreakseo.com>"
OUTREACH_FROM="FunBreak SEO <pr@funbreakseo.com>"

# Frontend URL (used in email links — verify/reset-password)
FRONTEND_URL=https://funbreakseo.com
APP_BASE_URL=https://api.funbreakseo.com

# Outreach IMAP (optional — for reply monitoring)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=

# Admin notification
ADMIN_EMAIL=doganizzetcan@gmail.com
ADMIN_FINANCIAL_DIGEST_FREQUENCY=WEEKLY

# Exchange Rate API
EXCHANGE_RATE_API_KEY=your-key
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6

# Storage (optional - Contabo Object Storage compatible)
S3_ENDPOINT=https://eu2.contabostorage.com
S3_BUCKET=funbreakseo
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=eu-central-1

# Sentry (optional)
SENTRY_DSN=

# VAT Rate
VAT_RATE=0.20

# KDV / Tax
DEFAULT_CURRENCY=TRY

# Feature flags
AUTOPILOT_ENABLED=true
STRIPE_ENABLED=false

# URLs for emails
SUPPORT_PHONE=+905334488253
SUPPORT_EMAIL=destek@funbreakseo.com
WHATSAPP_NUMBER=905334488253
