  updatedAt      DateTime @updatedAt

  @@unique([organizationId, metric], name: "orgId_metric")
  @@map("quota_overrides")
}

// ============================================================
// EMAIL LOG
// ============================================================

model EmailLog {
  id             String   @id @default(uuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  to             String
  subject        String
  body           String   @db.Text
  type           String   @default("SYSTEM")
  sentAt         DateTime @default(now())

  @@index([organizationId])
  @@map("email_logs")
}

// ============================================================
// DEVELOPER API KEY & USAGE
// ============================================================

model DeveloperApiKey {
  id             String   @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  keyHash        String   @unique
  scopes         Json?
  rateLimit      Int      @default(1000)
  revokedAt      DateTime?
  lastUsedAt     DateTime?
  usageLogs      ApiKeyUsage[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@map("developer_api_keys")
}

model ApiKeyUsage {
  id              String          @id @default(uuid())
  developerApiKeyId String
  developerApiKey DeveloperApiKey @relation(fields: [developerApiKeyId], references: [id], onDelete: Cascade)
  endpoint        String
  method          String          @default("GET")
  statusCode      Int?
  createdAt       DateTime        @default(now())

  @@index([developerApiKeyId])
  @@map("api_key_usages")
}

// ============================================================
// LEAD
// ============================================================

model Lead {
  id        String   @id @default(uuid())
  email     String
  name      String?
  domain    String?
  phone     String?
  source    String?
  meta      Json?
  createdAt DateTime @default(now())

  @@index([email])
  @@map("leads")
}

// ============================================================
// REPORT RECORD
// ============================================================

model ReportRecord {
  id        String      @id @default(uuid())
  projectId String
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  format    ReportFormat
  data      Json
  createdAt DateTime    @default(now())

  @@index([projectId])
  @@map("report_records")
}

// ============================================================
// AFFILIATE CLICK / CONVERSION / COMMISSION / PAYOUT
// ============================================================

model AffiliateClick {
  id          String    @id @default(uuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  userAgent   String?
  ip          String?
  createdAt   DateTime  @default(now())

  @@index([affiliateId])
  @@map("affiliate_clicks")
}

model AffiliateConversion {
  id             String    @id @default(uuid())
  affiliateId    String
  affiliate      Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  referredOrgId  String?
  referredOrg    Organization? @relation(fields: [referredOrgId], references: [id])
  type           String    @default("SIGNUP")
  planId         String?
  amount         Decimal?  @db.Decimal(10, 2)
  createdAt      DateTime  @default(now())

  @@index([affiliateId])
  @@map("affiliate_conversions")
}

model AffiliateCommission {
  id          String    @id @default(uuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  amount      Decimal   @db.Decimal(10, 2)
  status      String    @default("PENDING")
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([affiliateId])
  @@map("affiliate_commissions")
}

model AffiliatePayout {
  id          String    @id @default(uuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)
  amount      Decimal   @db.Decimal(10, 2)
  status      String    @default("PENDING")
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([affiliateId])
  @@map("affiliate_payouts")
}

// ============================================================
// MARKETPLACE DISPUTE
// ============================================================

model MarketplaceDispute {
  id        String   @id @default(uuid())
  orderId   String?
  offerId   String?
  buyerId   String?
  buyer     User?    @relation("BuyerDisputes", fields: [buyerId], references: [id])
  sellerId  String?
  seller    User?    @relation("SellerDisputes", fields: [sellerId], references: [id])
  offer     PublisherOffer? @relation(fields: [offerId], references: [id])
  reason    String?
  status    String   @default("OPEN")
  resolvedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("marketplace_disputes")
}

// ============================================================
// INTERNAL LINK SUGGESTION
// ============================================================

model InternalLinkSuggestion {
  id                String   @id @default(uuid())
  projectId         String?
  project           Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceBlogPostId  String?
  targetBlogPostId  String?
  sourceUrl         String?
  targetUrl         String?
  anchorText        String?
  relevance         Float?
  score             Float?
  isApplied         Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@index([projectId])
  @@map("internal_link_suggestions")
}

model AdminNotification {
  id        String   @id @default(uuid())
  type      String
  title     String
  body      String
  meta      Json?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("admin_notifications")
}

// ============================================================
// GEO VISIBILITY CHECK
// ============================================================

model GeoVisibilityCheck {
  id          String   @id @default(uuid())
  keywordId   String
  keyword     Keyword  @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  platform    String
  query       String
  isMentioned Boolean  @default(false)
  position    Int?
  excerpt     String?  @db.Text
  checkedAt   DateTime @default(now())

  @@index([keywordId])
  @@map("geo_visibility_checks")
}

// ============================================================
// ONBOARDING STATUS
// ============================================================

model OnboardingStatus {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  isComplete     Boolean      @default(false)
  currentStep    String       @default("welcome")
  steps          Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("onboarding_statuses")
}
