// FunBreak SEO — Full Prisma Schema
// All tables, relations, enums as per MASTER_PROMPT specification

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  SUPER_ADMIN
  ADMIN
  STAFF
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum OrgMemberRole {
  OWNER
  MEMBER
  VIEWER
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  SUSPENDED
  CANCELED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum InvoiceStatus {
  PAID
  UNPAID
  REFUNDED
}

enum WalletTxType {
  TOPUP
  SPEND
  REFUND
  CREDIT
  ESCROW_HOLD
  ESCROW_RELEASE
}

enum UsageMetric {
  KEYWORDS_TRACKED
  CRAWLS
  AI_BLOGS
  GEO_QUERIES
  OUTREACH_SENT
}

enum ProjectStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum KeywordIntent {
  INFORMATIONAL
  NAVIGATIONAL
  TRANSACTIONAL
  COMMERCIAL
}

enum TrackingDepth {
  FIRST_PAGE
  TOP_100
}

enum CrawlJobStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

enum CrawlTrigger {
  MANUAL
  SCHEDULED
}

enum IssueSeverity {
  CRITICAL
  WARNING
  NOTICE
}

enum IssueCategory {
  TITLE
  META
  HEADING
  CONTENT
  TECHNICAL
  SPEED
  SCHEMA
  LINKS
  MOBILE
  SECURITY
}

enum ContentType {
  BLOG
  PRODUCT_DESC
  META
  FAQ
  LANDING
}

enum ContentStatus {
  DRAFT
  GENERATING
  REVIEW
  APPROVED
  PUBLISHED
  REJECTED
}

enum GeoplatForm {
  CHATGPT
  GEMINI
  PERPLEXITY
  CLAUDE
  GOOGLE_AI_OVERVIEW
  GOOGLE_AI_MODE
}

enum Sentiment {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum GeoQueryStatus {
  ACTIVE
  PAUSED
}

enum OutreachCampaignStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

enum ProspectStatus {
  FOUND
  CONTACTED
  REPLIED_POSITIVE
  REPLIED_NEGATIVE
  WON
  LOST
  BOUNCED
}

enum ProspectFoundVia {
  SEARCH
  GUEST_POST_SIGNAL
  JOURNALIST
}

enum EmailStatus {
  QUEUED
  SENT
  OPENED
  REPLIED
  BOUNCED
}

enum ReplyClassification {
  INTERESTED
  NOT_INTERESTED
  QUESTION
  NEGOTIATION
  AUTO_REPLY
}

enum OfferStatus {
  PENDING_ADMIN_REVIEW
  APPROVED
  REJECTED
  NEGOTIATING
}

enum PublisherSiteAddedVia {
  MANUAL
  OUTREACH_AUTO
}

enum MarketLinkType {
  GUEST_POST
  NICHE_EDIT
  HOMEPAGE
}

enum OrderStatus {
  PENDING_PAYMENT
  ESCROW_HELD
  CONTENT_READY
  PUBLISHED
  VERIFIED
  COMPLETED
  DISPUTED
  REFUNDED
}

enum NotificationStatus {
  UNREAD
  READ
}

enum ApiProvider {
  GSC
  GA4
  DATAFORSEO
}

enum ReportFrequency {
  WEEKLY
  MONTHLY
}

enum ReportFormat {
  PDF
  EMAIL
  HTML
  JSON
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
  WAITING_CUSTOMER
  IN_PROGRESS
}

enum PendingProjectStatus {
  WATCHING
  EXPIRED
  CONVERTED
}

enum AutopilotPublishMode {
  AUTO
  SEMI_AUTO
}

enum AutopilotKeywordStatus {
  DISCOVERED
  QUEUED
  IN_PROGRESS
  GENERATED
  PUBLISHED
  SKIPPED
  FAILED
  NEEDS_REVIEW
  COMPLETED
}

enum AutopilotRunStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum DigestFrequency {
  DAILY
  WEEKLY
  MONTHLY
  OFF
}

enum ConsentType {
  DISTANCE_SALES
  PRE_INFO
  TERMS
  KVKK
  COOKIE
}

enum LegalDocumentType {
  DISTANCE_SALES
  PRE_INFO
  TERMS
  KVKK
  PRIVACY
  COOKIE
  REFUND
}

enum SystemHealthStatus {
  UP
  DEGRADED
  DOWN
}

enum SystemHealthService {
  DB
  REDIS
  WORKER
  DISK
  DATAFORSEO
  LLM
  SMTP
}

enum ChurnRisk {
  LOW
  MEDIUM
  HIGH
}

enum CouponType {
  PERCENT
  FIXED
  FIRST_MONTH_FREE
}

enum InvoiceType {
  INDIVIDUAL
  CORPORATE
}

enum CancellationReason {
  TOO_EXPENSIVE
  MISSING_FEATURE
  NOT_USING
  SWITCHING
  OTHER
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum BacklinkStatus {
  ACTIVE
  LOST
}

enum AbTestStatus {
  RUNNING
  COMPLETED
  PAUSED
}

enum PublisherSiteStatus {
  APPROVED
  PAUSED
}

// ============================================================
// MODELS
// ============================================================

model User {
  id                String          @id @default(uuid())
  email             String          @unique
  passwordHash      String
  fullName          String
  phone             String?
  role              UserRole        @default(CUSTOMER)
  emailVerified     Boolean         @default(false)
  emailVerifyToken  String?
  twoFactorEnabled  Boolean         @default(false)
  twoFactorSecret   String?
  avatarUrl         String?
  locale            String          @default("tr")
  lastLoginAt       DateTime?
  status            UserStatus      @default(PENDING)
  organizationId    String?
  organization      Organization?   @relation(fields: [organizationId], references: [id])
  refreshTokens     RefreshToken[]
  auditLogs         AuditLog[]      @relation("Actor")
  consentRecords    ConsentRecord[]
  notifications     Notification[]
  supportTickets        SupportTicket[]
  supportMessages       SupportMessage[]  @relation("MessageSender")
  supportMessagesUser   SupportMessage[]  @relation("MessageUser")
  createdTickets        SupportTicket[]   @relation("TicketCreatedBy")
  assignedTickets       SupportTicket[]   @relation("TicketAssignedTo")
  contentItems      ContentItem[]   @relation("CreatedBy")
  contentReviewed   ContentItem[]   @relation("ReviewedBy")
  orgMemberships      OrganizationMember[]
  createdProjects     Project[]
  emailCampaigns      EmailCampaign[]
  buyerDisputes       MarketplaceDispute[] @relation("BuyerDisputes")
  sellerDisputes      MarketplaceDispute[] @relation("SellerDisputes")
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  deletedAt           DateTime?

  @@map("users")
}

model Organization {
  id                    String                 @id @default(uuid())
  name                  String
  slug                  String                 @unique
  taxNumber             String?
  taxOffice             String?
  billingAddress        String?
  country               String                 @default("TR")
  ownerUserId           String
  walletBalance         Decimal                @default(0) @db.Decimal(18, 2)
  status                OrganizationStatus     @default(ACTIVE)
  referralCode          String?
  referredByAffiliateId String?
  digestFrequency       DigestFrequency        @default(WEEKLY)
  users                 User[]
  members               OrganizationMember[]
  projects              Project[]
  pendingProjects       PendingProject[]
  subscription          Subscription?
  invoices              Invoice[]
  walletTransactions    WalletTransaction[]
  usageRecords          UsageRecord[]
  apiIntegrations       ApiIntegration[]
  scheduledReports      ScheduledReport[]
  onboardingProgress    OnboardingProgress[]
  supportTickets        SupportTicket[]
  affiliate             Affiliate?
  apiKeys               ApiKey[]
  billingProfile        BillingProfile?
  cancellationFeedback  CancellationFeedback[]
  notificationPref      NotificationPreference?
  couponRedemptions     CouponRedemption[]
  customerHealthScore   CustomerHealthScore?
  consentRecords        ConsentRecord[]
  backlinkOrders        BacklinkOrder[]
  wallet                Wallet?
  apiUsageLogs          ApiUsageLog[]
  quotaOverrides        QuotaOverride[]
  emailLogs             EmailLog[]
  developerApiKeys      DeveloperApiKey[]
  affiliateConversions  AffiliateConversion[]
  onboardingStatus      OnboardingStatus?
  gscAccessToken        String?
  gscRefreshToken       String?
  gscTokenExpiry        DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  @@map("organizations")
}

model OrganizationMember {
  id             String        @id @default(uuid())
  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id])
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  role           OrgMemberRole @default(MEMBER)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model RefreshToken {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash   String    @unique
  expiresAt   DateTime
  revokedAt   DateTime?
  userAgent   String?
  ip          String?
  createdAt   DateTime  @default(now())

  @@map("refresh_tokens")
}

model AuditLog {
  id             String   @id @default(uuid())
  actorUserId    String?
  actor          User?    @relation("Actor", fields: [actorUserId], references: [id])
  userId         String?
  organizationId String?
  action         String
  entityType     String   @default("system")
  entityId       String?
  meta           Json?
  ip             String?
  createdAt      DateTime @default(now())

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model ConsentRecord {
  id               String       @id @default(uuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id])
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id])
  consentType      ConsentType
  documentVersion  String
  documentSnapshot String       @db.Text
  acceptedAt       DateTime     @default(now())
  ip               String?
  userAgent        String?
  legalDocumentId  String?
  legalDocument    LegalDocument? @relation(fields: [legalDocumentId], references: [id])

  @@index([userId])
  @@index([organizationId])
  @@map("consent_records")
}

model LegalDocument {
  id            String            @id @default(uuid())
  type          LegalDocumentType
  version       String
  locale        String            @default("tr")
  content       String            @db.Text
  effectiveDate DateTime
  isActive      Boolean           @default(true)
  consentRecords ConsentRecord[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([type, locale, version])
  @@map("legal_documents")
}

// ============================================================
// BILLING & SUBSCRIPTION
// ============================================================

model Plan {
  id             String         @id @default(uuid())
  name           String
  slug           String         @unique
  monthlyPrice   Decimal        @db.Decimal(10, 2)
  yearlyPrice    Decimal        @db.Decimal(10, 2)
  currency       String         @default("TRY")
  isActive       Boolean        @default(true)
  sortOrder      Int            @default(0)
  limits         Json
  subscriptions  Subscription[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("plans")
}

model Subscription {
  id                      String             @id @default(uuid())
  organizationId          String             @unique
  organization            Organization       @relation(fields: [organizationId], references: [id])
  planId                  String
  plan                    Plan               @relation(fields: [planId], references: [id])
  status                  SubscriptionStatus @default(TRIALING)
  billingCycle            BillingCycle       @default(MONTHLY)
  currentPeriodStart      DateTime
  currentPeriodEnd        DateTime
  trialEndsAt             DateTime?
  cancelAtPeriodEnd       Boolean            @default(false)
  paymentProviderRef      String?
  pastDueSince            DateTime?
  isComplimentary         Boolean            @default(false)
  complimentaryReason     String?
  complimentaryUntil      DateTime?
  canceledAt              DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  @@map("subscriptions")
}

model Invoice {
  id                  String        @id @default(uuid())
  organizationId      String
  organization        Organization  @relation(fields: [organizationId], references: [id])
  subscriptionId      String?
  number              String        @unique
  amount              Decimal       @db.Decimal(10, 2)
  tax                 Decimal       @db.Decimal(10, 2)
  total               Decimal       @db.Decimal(10, 2)
  currency            String        @default("TRY")
  status              InvoiceStatus @default(UNPAID)
  pdfUrl              String?
  paymentProviderRef  String?
  parasutInvoiceId    String?
  parasutStatus       String?
  refundedAmount      Decimal?      @db.Decimal(10, 2)
  issuedAt            DateTime      @default(now())
  paidAt              DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([organizationId])
  @@map("invoices")
}

model WalletTransaction {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  type           WalletTxType
  amount         Decimal      @db.Decimal(10, 2)
  balanceAfter   Decimal      @db.Decimal(10, 2)
  refType        String?
  refId          String?
  description    String?
  createdAt      DateTime     @default(now())

  @@index([organizationId])
  @@map("wallet_transactions")
}

model UsageRecord {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  metric         UsageMetric
  value          Int
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime     @default(now())

  @@index([organizationId, metric])
  @@map("usage_records")
}

model BillingProfile {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  invoiceType    InvoiceType  @default(INDIVIDUAL)
  companyTitle   String?
  taxOffice      String?
  taxNumber      String?
  tckn           String?
  address        String?
  city           String?
  country        String       @default("TR")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("billing_profiles")
}

model Coupon {
  id               String            @id @default(uuid())
  code             String            @unique
  type             CouponType
  value            Decimal           @db.Decimal(10, 2)
  maxRedemptions   Int?
  redemptionCount  Int               @default(0)
  validFrom        DateTime
  validUntil       DateTime?
  applicablePlans  Json?
  isActive         Boolean           @default(true)
  redemptions      CouponRedemption[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("coupons")
}

model CouponRedemption {
  id              String       @id @default(uuid())
  couponId        String
  coupon          Coupon       @relation(fields: [couponId], references: [id])
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  discountApplied Decimal      @db.Decimal(10, 2)
  redeemedAt      DateTime     @default(now())

  @@unique([couponId, organizationId])
  @@map("coupon_redemptions")
}

model CancellationFeedback {
  id             String             @id @default(uuid())
  organizationId String
  organization   Organization       @relation(fields: [organizationId], references: [id])
  reason         CancellationReason
  comment        String?
  offerShown     String?
  offerAccepted  Boolean            @default(false)
  canceledAt     DateTime           @default(now())

  @@map("cancellation_feedback")
}

// ============================================================
// PROJECTS & SEO CORE
// ============================================================

model Project {
  id                    String              @id @default(uuid())
  organizationId        String
  organization          Organization        @relation(fields: [organizationId], references: [id])
  name                  String
  domain                String
  faviconUrl            String?
  country               String              @default("TR")
  language              String              @default("tr")
  searchEngine          String              @default("google.com.tr")
  status                ProjectStatus       @default(ACTIVE)
  healthScore           Int                 @default(0)
  geoVisibilityScore    Int                 @default(0)
  gscConnected          Boolean             @default(false)
  createdByUserId       String
  createdBy             User                @relation(fields: [createdByUserId], references: [id])
  keywords              Keyword[]
  competitors           Competitor[]
  backlinks             Backlink[]
  crawlJobs             CrawlJob[]
  contentItems          ContentItem[]
  geoQueries            GeoQuery[]
  geoSnapshots          GeoVisibilitySnapshot[]
  geoCompetitors        GeoCompetitor[]
  outreachCampaigns     OutreachCampaign[]
  backlinkOrders        BacklinkOrder[]
  scheduledReports      ScheduledReport[]
  apiIntegrations       ApiIntegration[]
  contentProject        ContentProject?
  reportRecords         ReportRecord[]
  internalLinkSuggestions InternalLinkSuggestion[]
  scanHistory           ScanHistory[]
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  deletedAt             DateTime?

  @@index([organizationId])
  @@map("projects")
}

/// Archived snapshot of a completed Full Scan — lets customers browse past
/// scans by date and reopen each report.
model ScanHistory {
  id                 String   @id @default(uuid())
  projectId          String
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  healthScore        Int      @default(0)
  pagesScanned       Int      @default(0)
  issuesFound        Int      @default(0)
  keywordCount       Int      @default(0)
  rankedCount        Int      @default(0)
  firstPageCount     Int      @default(0)
  avgPosition        Float?
  backlinkCount      Int      @default(0)
  referringDomains   Int      @default(0)
  geoVisibilityScore Int      @default(0)
  geoMentions        Int      @default(0)
  geoCitations       Int      @default(0)
  competitorCount    Int      @default(0)
  data               Json?
  createdAt          DateTime @default(now())

  @@index([projectId, createdAt])
  @@map("scan_history")
}

model PendingProject {
  id                String               @id @default(uuid())
  organizationId    String
  organization      Organization         @relation(fields: [organizationId], references: [id])
  domain            String
  attemptedByUserId String
  attemptedAt       DateTime             @default(now())
  status            PendingProjectStatus @default(WATCHING)
  watchUntil        DateTime
  lightSnapshotJson Json?
  adminNotified     Boolean              @default(false)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([organizationId])
  @@map("pending_projects")
}

model Keyword {
  id             String        @id @default(uuid())
  projectId      String
  project        Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phrase         String
  location       String        @default("Turkey")
  language       String        @default("tr")
  searchVolume   Int?
  difficulty     Int?
  cpc            Decimal?      @db.Decimal(10, 2)
  intent         KeywordIntent @default(INFORMATIONAL)
  trackingDepth  TrackingDepth @default(FIRST_PAGE)
  isStarred      Boolean       @default(false)
  tagId               String?
  tag                 KeywordTag?          @relation(fields: [tagId], references: [id])
  ranks               KeywordRank[]
  geoVisibilityChecks GeoVisibilityCheck[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@unique([projectId, phrase, location])
  @@index([projectId])
  @@map("keywords")
}

model KeywordRank {
  id               String    @id @default(uuid())
  keywordId        String
  keyword          Keyword   @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  position         Int?
  previousPosition Int?
  url              String?
  serpFeatures     Json?
  checkedAt        DateTime  @default(now())

  @@index([keywordId])
  @@index([checkedAt])
  @@map("keyword_ranks")
}

model KeywordTag {
  id        String    @id @default(uuid())
  projectId String
  name      String
  color     String    @default("#5B8DEF")
  keywords  Keyword[]
  createdAt DateTime  @default(now())

  @@unique([projectId, name])
  @@map("keyword_tags")
}

model Competitor {
  id               String  @id @default(uuid())
  projectId        String
  project          Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  domain           String
  isAuto           Boolean @default(false)
  visibilityScore  Int     @default(0)
  commonKeywords   Int     @default(0)
  avgPosition      Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([projectId, domain])
  @@map("competitors")
}

model Backlink {
  id            String        @id @default(uuid())
  projectId     String
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceDomain  String
  sourceUrl     String
  targetUrl     String
  anchorText    String?
  domainRating  Int?
  isDofollow    Boolean       @default(true)
  firstSeen     DateTime
  lastSeen      DateTime
  status        BacklinkStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([projectId])
  @@map("backlinks")
}

// ============================================================
// CRAWLER & TECHNICAL SEO
// ============================================================

model CrawlJob {
  id           String         @id @default(uuid())
  projectId    String
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status       CrawlJobStatus @default(QUEUED)
  startedAt    DateTime?
  finishedAt   DateTime?
  pagesScanned Int            @default(0)
  issuesFound  Int            @default(0)
  healthScore  Int?
  triggeredBy  CrawlTrigger   @default(MANUAL)
  pages        CrawledPage[]
  issues       SeoIssue[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([projectId])
  @@map("crawl_jobs")
}

model CrawledPage {
  id               String    @id @default(uuid())
  crawlJobId       String
  crawlJob         CrawlJob  @relation(fields: [crawlJobId], references: [id], onDelete: Cascade)
  url              String
  statusCode       Int?
  title            String?
  titleLength      Int?
  metaDescription  String?
  metaLength       Int?
  h1Count          Int       @default(0)
  wordCount        Int       @default(0)
  loadTimeMs       Int?
  isIndexable      Boolean   @default(true)
  canonicalUrl     String?
  hasSchema        Boolean   @default(false)
  depth            Int       @default(0)
  issues           SeoIssue[]
  createdAt        DateTime  @default(now())

  @@index([crawlJobId])
  @@map("crawled_pages")
}

model SeoIssue {
  id              String        @id @default(uuid())
  crawlJobId      String
  crawlJob        CrawlJob      @relation(fields: [crawlJobId], references: [id], onDelete: Cascade)
  crawledPageId   String?
  crawledPage     CrawledPage?  @relation(fields: [crawledPageId], references: [id])
  ruleId          String?
  rule            SeoRuleDefinition? @relation(fields: [ruleId], references: [id])
  category        IssueCategory
  severity        IssueSeverity
  code            String
  message         String
  recommendation  String?
  autoFixable     Boolean       @default(false)
  fixed           Boolean       @default(false)
  createdAt       DateTime      @default(now())

  @@index([crawlJobId])
  @@map("seo_issues")
}

model SeoRuleDefinition {
  id               String        @id @default(uuid())
  code             String        @unique
  category         IssueCategory
  severity         IssueSeverity
  titleTr          String
  descriptionTr    String
  recommendationTr String
  weight           Int           @default(1)
  autoFixable      Boolean       @default(false)
  issues           SeoIssue[]
  createdAt        DateTime      @default(now())

  @@map("seo_rule_definitions")
}

// ============================================================
// CONTENT ENGINE
// ============================================================

model ContentProject {
  id              String  @id @default(uuid())
  projectId       String  @unique
  project         Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  defaultTone     String  @default("professional")
  defaultLanguage String  @default("tr")
  brandVoiceNotes String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("content_projects")
}

model ContentItem {
  id                  String          @id @default(uuid())
  projectId           String
  project             Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type                ContentType     @default(BLOG)
  title               String
  slug                String
  focusKeyword        String?
  secondaryKeywords   Json?
  status              ContentStatus   @default(DRAFT)
  bodyMarkdown        String?         @db.Text
  bodyHtml            String?         @db.Text
